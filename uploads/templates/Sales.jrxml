	<subDataset name="grid" uuid="74a118b0-b6f5-402f-bbdb-d651cde1b72c">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DB"/>
		<parameter name="fk" class="java.lang.Integer"/>
		<queryString language="SQL">
			<![CDATA[select p.description,s.qty,s.ngrate rate,s.ngamount ngamount,p.hsnCode ,s.uom,s.cgst_per,s.cgst_per,s.igst_per,s.sgst_amt,s.cgst_amt,s.igst_amt,s.amount,s.Gst
from sales s 
left Join barcode b on s.item = b.id
Join products p on p.name = b.product
 where s.fk= $P{fk}]]>
		</queryString>

	<subDataset name="GST" uuid="2bd119f2-9d98-4c34-a16a-84d7274e54ac">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DB"/>
		<parameter name="fk" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[$P{fk}]]></defaultValueExpression>
		</parameter>
		<queryString language="SQL">
			<![CDATA[SELECT ord, gst_desc, gst_amt FROM (
        SELECT 1 ord, 'Gross Amount' gst_desc, 0 gst_per, round( SUM(ngamount),2) gst_amt   
        FROM sales WHERE fk = $P{fk}
        UNION ALL
        SELECT 2 ord, 'Discount Amount', 0, round( SUM(disc_amt),2)   
        FROM sales WHERE fk = $P{fk}
        UNION ALL
        SELECT 3 ord, CONCAT('CGST@', cgst_per, '%') gst_desc, 
               MAX(cgst_per) gstper,
                SUM(cgst_amt) gstamt   
        FROM sales WHERE fk = $P{fk} AND cgst_amt > 0
        GROUP BY CONCAT('CGST@', cgst_per, '%')
        UNION ALL
        SELECT 4 ord, CONCAT('SGST@', sgst_per, '%') gst_desc, 
               MAX(sgst_per) gstper, 
               SUM(sgst_amt) gstamt   
        FROM sales WHERE fk = $P{fk} AND sgst_amt > 0
        GROUP BY CONCAT('SGST@', sgst_per, '%')
        UNION ALL
        SELECT 5 ord, CONCAT('IGST@', igst_per, '%') gst_desc, 
               MAX(igst_per) gstper, SUM(igst_amt) gstamt   
        FROM sales WHERE fk = $P{fk} AND igst_amt > 0
        GROUP BY CONCAT('IGST@', igst_per, '%')
        UNION ALL
      SELECT 6 ord, case  when  sum(amount) - floor(sum(amount)) >=0.5 then 'Round off Add(+)' else 'Round off Less(-)' 
      end , 98, case  when  sum(amount) - floor(sum(amount)) >=0.5 then round(  (100 - ( ( round(sum(amount) - floor(sum(amount)),2)) * 100))/100,2)
      else round(  sum(ngamount+sgst_amt+cgst_amt) - floor(sum(ngamount+sgst_amt+cgst_amt)),2) end amt
      FROM erp.sales where fk=$P{fk}
        UNION ALL
        SELECT 7 ord, 'Net Amount', 99, 
               ROUND(SUM(ngamount+sgst_amt+cgst_amt), 0)    
        FROM sales WHERE fk=$P{fk}
      ) a
      WHERE gst_amt <> 0 
      ORDER BY gst_per, ord]]>
		</queryString>
		<field name="ord" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="ord"/>
			<property name="com.jaspersoft.studio.field.label" value="ord"/>
		</field>
		<field name="gst_desc" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="gst_desc"/>
			<property name="com.jaspersoft.studio.field.label" value="gst_desc"/>
		</field>
		<field name="gst_amt" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.name" value="gst_amt"/>
			<property name="com.jaspersoft.studio.field.label" value="gst_amt"/>
		</field>
	</subDataset>
	<subDataset name="terms" uuid="3d4bf5f2-3651-49d2-bd7b-19ce2c5e0d35">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DB"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<parameter name="fk" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[SELECT tempname,
	tempvalue
FROM templete temp
	left JOIN erp.salesp sp ON 
	 sp.`paytermsId` = temp.`fk`
WHERE 
	 sp.`Id` = $P{fk}]]>
		</queryString>
		<field name="tempname" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="tempname"/>
			<property name="com.jaspersoft.studio.field.label" value="tempname"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="templete"/>
		</field>
		<field name="tempvalue" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="tempvalue"/>
			<property name="com.jaspersoft.studio.field.label" value="tempvalue"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="templete"/>
		</field>
	</subDataset>
	<parameter name="salesPId" class="java.lang.Integer"/>
	<parameter name="entryId" class="java.lang.String"/>
	<parameter name="finyearId" class="java.lang.String"/>
	<parameter name="branchId" class="java.lang.Integer"/>
	<parameter name="invtype" class="java.lang.String"/>
	<parameter name="fk" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
    sp.Id,
    sp.entryId AS invoice_no,
    sp.date,
    DATE_FORMAT(sp.date, '%d/%m/%Y') AS formatted_invoice_date,
    sp.amount,
    sp.cash_credit AS payment_type,
    comp.name AS company_name,
    comp.gst AS company_gst,
    br.name AS branch_name,
    party.name AS customer_name,
    party.gst AS customer_gst,
    addr.address1 partyadd1,
    addr.address2 partyadd2,
    addr.address3 partyadd3,
    
    addr.address1 branchadd1,
    addr.address2 branchadd2,
    addr.address3 branchadd3,
    
    bnk.bank_name  bank_name,
    bnk.account_number account_number,
    bnk.ifsc_code   ifsc_code,
    bnk.branch_name  branch_name,
    
    billadd.address1 billadd1,
    billadd.address2 billadd2,
    billadd.address3 billadd3,
    
    CONCAT_WS(', ', addr.address1, dist.district, st.state) AS customer_address,
    COUNT(DISTINCT sale.Id) AS total_items,
    COALESCE(SUM(sale.qty), 0) AS total_quantity,
    COALESCE(SUM(sale.amount), 0) AS total_amount
FROM salesP sp
LEFT JOIN company comp ON sp.companyId = comp.id
LEFT JOIN branch br ON sp.branchId = br.id
LEFT JOIN party party ON sp.party = party.id
LEFT JOIN address addr ON addr.branchId = br.id
LEFT JOIN address billadd ON billadd.id = sp.billto

LEFT JOIN district dist ON party.district = dist.id
LEFT JOIN state st ON party.state = st.id
LEFT JOIN sales sale ON sp.Id = sale.fk
LEFT JOIN bank_details bnk ON bnk.branchId=br.id

WHERE 1=1
    -- Filter by SalesP ID (using sp.Id)
    AND ($P{salesPId} IS NULL OR sp.Id = $P{salesPId})
    
    -- Filter by Invoice Number (using entryId)
    AND ($P{entryId} IS NULL OR sp.entryId = $P{entryId})
    
    -- Filter by Branch ID
    AND ($P{branchId} IS NULL OR sp.branchId = $P{branchId})
    
    -- Filter by Financial Year
    AND ($P{finyearId} IS NULL OR sp.finyear = $P{finyearId})
GROUP BY 
    sp.Id,
    sp.entryId,
    sp.date,
    sp.amount,
    sp.cash_credit,
    comp.name,
    comp.gst,
    br.name,
    party.name,
    party.gst,
    addr.address1,
    addr.address2,
    addr.address3,
    dist.district,
    st.state,
    bnk.bank_name,
    bnk.account_number,
    bnk.ifsc_code,
    bnk.branch_name
ORDER BY sp.date DESC]]>
	</queryString>
